# Gemini API
GEMINI_API_KEY="your_google_ai_studio_api_key"

# Google Sheets
# Base64 encoded JSON to avoid formatting issues in PaaS environments.
GOOGLE_SHEETS_CREDENTIALS_BASE64="base64_encoded_google_service_account_json"
GOOGLE_SHEET_ID="your_target_google_sheet_id"

# Application Settings
ENVIRONMENT="development"
