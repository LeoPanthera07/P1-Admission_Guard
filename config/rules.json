{
  "schemaVersion": "2.0.0",
  "programStartDate": "2026-07-01",
  "softRuleKeywords": ["approved", "special case", "waiver"],
  "systemRules": {
    "maxSoftExceptions": 2,
    "rationaleMinLength": 10
  },
  "fields": {
    "fullName": {
      "label": "Full Name",
      "type": "text",
      "ruleType": "strict",
      "order": 1,
      "validations": { "required": true }
    },
    "email": {
      "label": "Email Address",
      "type": "text",
      "ruleType": "strict",
      "order": 2,
      "validations": { "required": true, "pattern": "^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$" }
    },
    "phone": {
      "label": "Phone Number",
      "type": "text",
      "ruleType": "strict",
      "order": 3,
      "validations": { "required": true }
    },
    "pathTaken": {
      "label": "Educational Path",
      "type": "select",
      "ruleType": "strict",
      "order": 4,
      "validations": { "required": true, "enum": ["A", "B", "C"] }
    },
    "tenthCompletionDate": {
      "label": "10th Completion Date",
      "type": "date",
      "ruleType": "strict",
      "order": 5,
      "validations": { "required": true }
    },
    "tenthScore": {
      "label": "10th Score (%)",
      "type": "number",
      "ruleType": "strict",
      "order": 6,
      "validations": { "required": true }
    },
    "itiCompletionDate": {
      "label": "ITI Completion Date (Path C)",
      "type": "date",
      "ruleType": "soft",
      "order": 7,
      "validations": { "required": false }
    },
    "itiScore": {
      "label": "ITI Score (%)",
      "type": "number",
      "ruleType": "soft",
      "order": 8,
      "validations": { "required": false }
    },
    "twelfthOrDiplomaCompletionDate": {
      "label": "12th/Diploma Completion Date",
      "type": "date",
      "ruleType": "strict",
      "order": 9,
      "validations": { "required": true }
    },
    "twelfthOrDiplomaScore": {
      "label": "12th/Diploma Score (%)",
      "type": "number",
      "ruleType": "strict",
      "order": 10,
      "validations": { "required": true }
    },
    "ugCompletionDate": {
      "label": "UG Completion Date",
      "type": "date",
      "ruleType": "strict",
      "order": 11,
      "validations": { "required": true }
    },
    "ugScore": {
      "label": "UG Score (%)",
      "type": "number",
      "ruleType": "strict",
      "order": 12,
      "validations": { "required": true }
    },
    "workStartDate": {
      "label": "Work Start Date",
      "type": "date",
      "ruleType": "soft",
      "order": 13,
      "validations": { "required": false }
    },
    "workEndDate": {
      "label": "Work End Date",
      "type": "date",
      "ruleType": "soft",
      "order": 14,
      "validations": { "required": false }
    }
  }
}